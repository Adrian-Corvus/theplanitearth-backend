{
  "version": 2,
  "functions": {
    "api/webhook.js":        { "maxDuration": 10 },
    "api/generate-brief.js": { "maxDuration": 60 },
    "api/parse-input.js":    { "maxDuration": 30 },
    "api/create-checkout.js":{ "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "https://theplanitearth.com" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
